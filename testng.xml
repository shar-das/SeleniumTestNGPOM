<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name = "Ecommerce Test Suite" parallel="false" thread-count="2">

	<listeners>
    <listener class-name="listeners.TestListener"/>
    <listener class-name="listeners.RetryTransformer"/>
	</listeners>

    <test name = "Automation Test">
    	<groups>
    		<run>
    			<include name="regression"></include>
    			<include name="smoke"></include>
    		</run>
    	</groups>
        <classes>
        	<class name = "tests.LoginTest" />
        	<class name = "tests.HomePageTest" />
        	<class name = "tests.ElectronicsPageTest" />
        	<class name = "tests.ElectronicProductPageTest" />           
        </classes>
    </test>

</suite>